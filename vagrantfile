Vagrant.configure("2") do |config|
  # Define the three nodes
  nodes = {
    "manager1" => "192.168.56.11",
    "worker1"  => "192.168.56.12",
    "worker2"  => "192.168.56.13"
  }

  nodes.each do |name, ip|
    config.vm.define name do |node|
      # Use the latest Ubuntu LTS available
      node.vm.box = "ubuntu/jammy64"   # ubuntu/jammy64 for windows 
      node.vm.network "private_network", ip: ip
    
      node.vm.provider "virtualbox" do |vb|
        vb.name = name
        vb.memory = 1024 # 1GB RAM per node is plenty for testing
        vb.cpus = 1
      end

      # Provisioner to install Docker automatically
      node.vm.provision "shell", path: "docker-provision.sh"
    end
  end
end

